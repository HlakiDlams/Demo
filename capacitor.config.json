{
  "appId": "com.hfactor543.studios",
  "appName": "HF543 Studios",
  "webDir": ".",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https"
  },
  "android": {
    "allowMixedContent": false,
    "captureInput": true,
    "webContentsDebuggingEnabled": false,
    "backgroundColor": "#080808"
  },
  "plugins": {
