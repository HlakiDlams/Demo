rules_version = '2';
// NOTE: These rules allow open read/write since the admin panel uses its own
// password auth (not Firebase Auth). The data here is non-sensitive site content.
// Tighten these by adding Firebase Auth integration in a future update.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
