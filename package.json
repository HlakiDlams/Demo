{
  "name": "hfactor543-studios",
  "version": "1.0.0",
  "description": "HFactor543 Studios — Creative Empire Mobile App",
  "main": "electron/main.js",
  "scripts": {
    "build": "node build-www.js",
    "cap:add": "npx cap add android",
    "cap:sync": "npx cap sync android",
    "cap:open": "npx cap open android",
    "cap:build": "npx cap build android",
    "make-icon": "node make-icon.js",
    "electron:start": "npm run build && electron .",
    "electron:build": "npm run build && npm run make-icon && electron-builder --win nsis"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "png-to-ico": "^2.1.8"
  },
  "build": {
    "appId": "com.hfactor543.studios",
    "productName": "HF543 Studios",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "www/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "keywords": ["hfactor543", "studios", "creative", "mobile", "pwa"],
  "author": "HFactor543 Studios",
  "license": "UNLICENSED",
  "private": true
}
